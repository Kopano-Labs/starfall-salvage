{
  "name": "starfall-salvage-monorepo",
  "version": "0.0.1",
  "private": true,
  "description": "Starfall Salvage — Kopano Labs WebGL game + Ionic React mobile rebuild",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "mobile:dev": "turbo run dev --filter=@starfall/mobile",
    "twa:doctor": "npm run doctor --workspace=@starfall/twa",
    "twa:build": "npm run build --workspace=@starfall/twa",
    "twa:validate": "npm run validate --workspace=@starfall/twa",
    "twa:verify-assetlinks": "npm run verify-assetlinks --workspace=@starfall/twa",
    "vault:check": "node --input-type=module < src/kopano-vault.js",
    "verify:syntax": "node --check src/game.js && python -m py_compile backend/starfall_server.py",
    "kc:audit": "python tools/kc_starfall_watch.py --once --skip-backend",
    "kc:audit:full": "python tools/kc_starfall_watch.py --once",
    "kc:audit:seed": "python tools/kc_starfall_watch.py --once --skip-backend --seed-kc",
    "kc:watch": "python tools/kc_starfall_watch.py --interval 60 --skip-backend",
    "gate": "npm run verify:syntax && python tools/hot_path_audit.py && npm run kc:audit",
    "hot-path:audit": "python tools/hot_path_audit.py",
    "mobile:stress:pw": "node tools/playwright_mobile_audit.js"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "npm@10.8.0"
}
