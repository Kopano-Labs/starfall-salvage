{
  "compilerOptions": {
    "target":            "ES2020",
    "lib":               ["ES2020", "DOM", "DOM.Iterable"],
    "module":            "ESNext",
    "moduleResolution":  "bundler",
    "jsx":               "react-jsx",
    "strict":            true,
    "esModuleInterop":   true,
    "skipLibCheck":      true,
    "resolveJsonModule": true,
    "isolatedModules":   true,
    "noEmit":            true,
    "paths": {
      "@starfall/ui":    ["../../packages/ui/src/index.ts"],
      "@starfall/vault": ["../../packages/vault/src/kopano-vault.js"]
    }
  },
  "include": ["src"]
}
