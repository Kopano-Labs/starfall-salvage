{
  "framework": null,
  "installCommand": "echo \"Static Starfall deploy: no dependency install\"",
  "buildCommand": "echo \"Static Starfall deploy: no build step\"",
  "outputDirectory": ".",
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ]
}
